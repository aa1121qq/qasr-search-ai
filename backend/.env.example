# OpenAI API key — https://platform.openai.com/api-keys
# Used for: query embeddings (text-embedding-3-small), AI features (gpt-4o-mini), image fallback (gpt-image-1/dall-e)
OPENAI_API_KEY=

# Elasticsearch cluster — https://cloud.elastic.co
# The 'products' index is created and populated by backend/scripts/*.js
ELASTIC_ENDPOINT=
ELASTIC_API_KEY=

# Google Gemini API key — https://aistudio.google.com/app/apikey
# Used for: Nano Banana (gemini-2.5-flash-image) compositing in /tansiq-compose
GEMINI_API_KEY=

# Backend server port (default 5000)
PORT=5000
